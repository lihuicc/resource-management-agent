{
  "xsappname": "resource-management-agent",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.user",
      "description": "Use resource management app"
    }
  ],
  "role-templates": [
    {
      "name": "User",
      "scope-references": ["$XSAPPNAME.user"]
    }
  ],
  "role-collections": [
    {
      "name": "ResourceManagement_User",
      "role-template-references": ["$XSAPPNAME.User"]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.eu12.hana.ondemand.com/**"
    ]
  }
}
