{
  "name": "resource-agent",
  "version": "1.0.0",
  "description": "Resource Management Agent on SAP BTP",
  "engines": { "node": ">=20" },
  "dependencies": {
    "@sap/cds": "^9",
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4",
    "multer": "^2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds-serve"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": { "url": "db/data.db" }
      }
    },
    "watch": {
      "livereload": false
    }
  }
}
